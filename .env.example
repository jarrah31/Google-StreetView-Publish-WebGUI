# Google API Credentials
GOOGLE_CLIENT_ID=your_client_id_here
GOOGLE_CLIENT_SECRET=your_client_secret_here
GOOGLE_MAPS_API_KEY=your_api_key_here
# IMPORTANT: Restrict this API key in Google Cloud Console to HTTP referrers only
# (e.g. http://127.0.0.1:5001/* and your production domain) to prevent misuse
# OAuth Redirect URI (must match the one in your Google Cloud Console)
REDIRECT_URI=http://127.0.0.1:5001/oauth2callback
# Flask secret key for session signing (generate with: python -c "import secrets; print(secrets.token_hex(32))")
# Optional: if not set, a persistent key is auto-generated and saved to
# userdata/.flask_secret_key (stable across restarts). Set this only if you want
# to control the key yourself or share it across multiple hosts.
FLASK_SECRET_KEY=
# Set to 0 if running behind HTTPS (default: 1 for local HTTP development)
OAUTHLIB_INSECURE_TRANSPORT=1

# OAuth client type: "web" (default) or "installed" (Desktop client).
# Most users create a Web OAuth client with an http://localhost redirect and can
# leave this unset. Only switch to "installed" if you created a Desktop client —
# useful if you want to publish your Google project to production (which forbids
# http redirects on web clients) while still authenticating over http loopback.
#OAUTH_CLIENT_TYPE=web

# Set to 1 ONLY when running behind a trusted reverse proxy that terminates TLS
# and sets X-Forwarded-Proto/Host. Required in that case so the OAuth callback
# URL is rebuilt as the external HTTPS URL. Leave unset/0 for direct local use.
#TRUST_PROXY=0
